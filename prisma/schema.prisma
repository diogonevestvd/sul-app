generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String
  locale       String      @default("pt")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  workspaces   Workspace[]
}

model Workspace {
  id           String        @id @default(cuid())
  title        String
  objective    String?
  summary      String?
  locale       String        @default("pt")
  userId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      Entry[]
  questions    Question[]
  planVersions PlanVersion[]
  notes        PreferenceNote[]
}

model Entry {
  id          String    @id @default(cuid())
  workspaceId String
  kind        String
  content     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Question {
  id          String    @id @default(cuid())
  workspaceId String
  key         String
  kind        String
  text        String
  hint        String
  stage       Int       @default(1)
  answer      String?
  optionsJson String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model PlanVersion {
  id          String    @id @default(cuid())
  workspaceId String
  title       String
  summary     String
  phasesJson  String
  source      String    @default("local-ai")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model PreferenceNote {
  id          String    @id @default(cuid())
  workspaceId String
  content     String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
